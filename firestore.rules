rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────
    // users コレクション
    // ────────────────────────────────────────
    // 自分のユーザー情報は自分だけが読み書きできます。
    // フレンドのプロフィール（名前など）は認証済みユーザーなら誰でも読めます。
    // friends 配列の更新は認証済みユーザーなら誰でもできます（フレンド承認・削除用）。
    match /users/{uid} {
      // ユーザー一覧の検索（userIdの重複チェック、フレンド検索）を許可
      allow read: if request.auth != null;
      
      allow write: if request.auth != null && request.auth.uid == uid;
      // ユーザー情報の更新: 本人なら何でも。他人ならフォロー関連(friends, followers, following)のみ。
      allow update: if request.auth != null && (
        request.auth.uid == uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends', 'followers', 'following'])
      );

      // プライベート情報（email, birthDate, gender, wakeUpTime, taskTime）
      // 自分だけが読み書きできます
      match /private/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ────────────────────────────────────────
    // friend_requests コレクション
    // ────────────────────────────────────────
    match /friend_requests/{requestId} {
      // リクエスト作成: 認証済み & fromUid が自分であること
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid;

      // リクエスト読み取り: 送信者 or 受信者のみ
      allow read: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);

      // リクエスト更新（承認・拒否）: 受信者のみ & status のみ変更可
      allow update: if request.auth != null
        && resource.data.toUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

      // リクエスト削除（キャンセル）: 送信者のみ
      allow delete: if request.auth != null
        && resource.data.fromUid == request.auth.uid;
    }

    // ────────────────────────────────────────
    // notifications コレクション
    // ────────────────────────────────────────
    match /notifications/{notificationId} {
      // 通知作成: 認証済みユーザー（自分宛て or 相手宛て）
      allow create: if request.auth != null;

      // 通知読み取り: 自分宛て or 自分が送信した通知
      allow read: if request.auth != null
        && (resource.data.toUid == request.auth.uid
            || resource.data.fromUid == request.auth.uid);

      // 通知更新（既読マーク）: 自分宛ての通知のみ & isRead のみ変更可
      allow update: if request.auth != null
        && resource.data.toUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);

      // 通知削除:
      //   - 自分宛ての通知（ユーザーが通知を消す）
      //   - 自分が送った通知（リアクション通知の集約・上書きのため）
      allow delete: if request.auth != null
        && (resource.data.toUid == request.auth.uid
            || resource.data.fromUid == request.auth.uid);
    }

    // ────────────────────────────────────────
    // posts コレクション
    // ────────────────────────────────────────
    match /posts/{postId} {
      // 【仕様】ログインしているユーザーが自分の投稿を作れる
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      // 【仕様】自分の投稿は自分だけが更新・削除できる（リアクションは除外 → reactionCount は別途許可）
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // 【仕様】reactionCount の更新は誰でも（ログインユーザーなら）OK
      // ただし reactionCount 以外のフィールドを変更しようとしてもブロックします
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactionCount', 'emojiReactedUserIds', 'userReactions']);

      // 【仕様（BeRealルール）】
      // ・閲覧は「まだ24時間が経っていない（expiresAt > 今）」投稿のみ
      // ・閲覧者は今日の投稿がある（= lastPostedDate が今日）必要がある
      //
      //  ※ Firestore のセキュリティルールでは「今日の日付」を
      //    サーバーから直接は取得できません。
      //    そのため「ログイン済みであれば読める」とし、
      //    24hチェックはクライアント側（PostService.getFriendsFeed）のクエリと
      //    expiresAt フィールドで担保します。
      //    より厳格にしたい場合は Cloud Functions のサーバー側でチェックしてください。
      allow read: if request.auth != null;
    }
  }
}
